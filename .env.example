# Database
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# When ready for PostgreSQL, replace with:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/portkey

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_PORT=8000